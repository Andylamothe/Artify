# Path to the GCP service-account JSON file used for BOTH Cloud Speech-to-Text
# and Vertex AI Gemini. Keep the JSON itself out of git - see apps/ar-web/creds/.
GOOGLE_APPLICATION_CREDENTIALS=./creds/gcp-service-account.json

# GCP project ID and Vertex AI region. Project ID is also embedded in the
# service-account JSON; this env var is required only if you want to override it.
GCP_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1

# Vertex AI Gemini model to use for Q&A answers.
VERTEX_AI_MODEL=gemini-1.5-flash
