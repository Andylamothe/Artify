{
  "name": "hackthesummit-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:host": "next dev --hostname 0.0.0.0 --port 3001",
    "dev:https": "next dev --hostname 0.0.0.0 --port 3000 --experimental-https",
    "dev:https:cert": "next dev --hostname 0.0.0.0 --port 3000 --experimental-https --experimental-https-key ./certs/dev-key.pem --experimental-https-cert ./certs/dev-cert.pem",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "compile:targets": "node scripts/compile-mind-targets.mjs"
  },
  "dependencies": {
    "aframe": "^1.7.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5"
  }
}
