{
  "name": "hackthesummit-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:host": "next dev --hostname 0.0.0.0 --port 3001",
    "dev:https": "next dev --hostname 0.0.0.0 --port 3000 --experimental-https",
    "dev:https:cert": "next dev --hostname 0.0.0.0 --port 3000 --experimental-https --experimental-https-key ./certs/dev-key.pem --experimental-https-cert ./certs/dev-cert.pem",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "compile:targets": "node scripts/compile-mind-targets.mjs",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.1",
    "@google/genai": "^2.6.0",
    "aframe": "^1.7.1",
    "google-auth-library": "^10.6.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "wasm-webp": "^0.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "ts-jest": "^29",
    "typescript": "^5"
  }
}
